# Vercel AI SDK reads this for @ai-sdk/google
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyYourApiKeyHere..."

# Passed to PrismaBetterSqlite3 adapter
DATABASE_URL="file:./dev.db"

# Fallback model: DeepSeek v4 Pro via NVIDIA build (https://build.nvidia.com)
# Used automatically when Gemini hits its rate limit quota.
NVIDIA_API_KEY="nvapi-YourKeyHere..."

# Optional: Enable Demo Mode for live presentations
# When 'true', bypasses AI generation and returns pre-baked demo data instantly.
# This protects against LLM outages, slow responses, and unpredictable outputs during live demos.
# Default: false
NEXT_PUBLIC_DEMO_MODE="false"